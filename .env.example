# Federal Reserve Economic Data (FRED) API key.
# Request a free key at https://fred.stlouisfed.org/docs/api/api_key.html.
# Without this key, FRED-sourced indicators fall back to fixture data.
FRED_API_KEY=

# World Bank Open Data base URL.
# Defaults to https://api.worldbank.org/v2 when this variable is unset; no API key is required.
# Set to a sandbox/proxy URL to override, or to an empty value to disable live calls and fall
# back to fixture data for World Bank-sourced indicators.
WORLD_BANK_BASE_URL=
