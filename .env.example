# Federal Reserve Economic Data (FRED) API key.
# Request a free key at https://fred.stlouisfed.org/docs/api/api_key.html.
# Without this key, FRED-sourced indicators fall back to fixture data.
FRED_API_KEY=

# World Bank Open Data base URL.
# Defaults to https://api.worldbank.org/v2 when this variable is unset; no API key is required.
# Set to a sandbox/proxy URL to override, or to an empty value to disable live calls and fall
# back to fixture data for World Bank-sourced indicators.
WORLD_BANK_BASE_URL=

# Override the per-frequency provider cache TTL with a single value in milliseconds.
# Leave unset to use the defaults (1h daily, 6h weekly, 24h monthly/quarterly/annual).
# Set to 0 to revalidate every request (cache stale-while-error path still applies).
CACHE_TTL_OVERRIDE_MS=

# OpenAI API key for the research copilot agent.
# Without this key, /api/chat returns a calm provider_error and the chat panel shows
# a fallback message. Server-side only; never expose to the client.
OPENAI_API_KEY=

# Override the model used by the research copilot agent. Defaults to gpt-4o-mini.
OPENAI_AGENT_MODEL=
